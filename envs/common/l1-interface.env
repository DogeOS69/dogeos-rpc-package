# L1 Interface Common Configuration

# Snapshot auto-download: if the DB doesn't exist on first start, the
# entrypoint downloads it from this URL. Supports .sqlite.gz, .tar.zst, .sqlite
# Leave empty to skip auto-download (manual restore via snapshot_testnet.md).
# L1_INTERFACE_SNAPSHOT_URL=https://example.com/l1-interface-snapshot.sqlite.gz

# API Configuration
DOGEOS_L1_INTERFACE_API_BIND_ADDRESS=0.0.0.0:8545
DOGEOS_L1_INTERFACE_BEACON_API_LISTEN_ADDRESS=0.0.0.0:5052
DOGEOS_L1_INTERFACE_HEALTH_LISTEN_ADDRESS=0.0.0.0:9090

# Database Configuration
DOGEOS_L1_INTERFACE_DATABASE_URL=sqlite:///data/l1-interface.sqlite

# Genesis Configuration
DOGEOS_L1_INTERFACE_GENESIS_JSON_PATH=/app/genesis/genesis.json
DOGEOS_L1_INTERFACE_SEQUENCER_GENESIS_MODE=false

# Logging
RUST_LOG=info 
