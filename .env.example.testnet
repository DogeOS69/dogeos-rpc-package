# Network Selection
NETWORK=testnet

# Docker Compose Project Name
# Used to isolate containers and volumes (e.g. dogeos-rpc-package_*)
COMPOSE_PROJECT_NAME=dogeos-rpc-package

# Docker Compose Profiles
# Select which ETH client to run: 'l2geth' or 'l2reth'
# IMPORTANT: Both l2geth and l2reth use the same ports (8545, 8546, 30303).
# You can only run ONE at a time. If you need to run both simultaneously,
# you must modify the port mappings in docker-compose.yml.
COMPOSE_PROFILES=l2geth

# Dogecoin Ports
DOGECOIN_P2P_PORT=44556
DOGECOIN_RPC_PORT=44555

# Dogecoin Memory Reservation
DOGECOIN_MEM_RESERVATION=14g

# Memory Limits (optional - uncomment to override defaults in docker-compose.yml)
# Adjust based on your host memory and expected RPC traffic.
# DOGECOIN_MEM_LIMIT=20g
# L2GETH_MEM_LIMIT=8g
# L2RETH_MEM_LIMIT=8g
# CELESTIA_MEM_LIMIT=6g
# L1_INTERFACE_MEM_LIMIT=2g
